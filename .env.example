# Copy this file to ".env" and fill in your real keys.
# Never commit the real .env file.

# Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily API key (used for web search) — get one at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: port the server runs on (defaults to 3000)
# PORT=3000
